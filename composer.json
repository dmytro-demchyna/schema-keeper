{
  "name": "schema-keeper/schema-keeper",
  "description": "Track PostgreSQL schema as one-file-per-object dumps. Detect drift in CI. Read-only — complements your migrations.",
  "minimum-stability": "stable",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "postgresql",
    "postgres",
    "pgsql",
    "database",
    "schema",
    "structure",
    "dump",
    "diff"
  ],
  "authors": [
    {
      "name": "Dmytro Demchyna",
      "email": "dmytro.demchyna@gmail.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "SchemaKeeper\\": "src/SchemaKeeper"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SchemaKeeper\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=7.4",
    "ext-pdo": "*",
    "ext-pdo_pgsql": "*",
    "sebastian/diff": "^4.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "mockery/mockery": "^1.5",
    "squizlabs/php_codesniffer": "^3.7",
    "friendsofphp/php-cs-fixer": "^3.93",
    "vimeo/psalm": "^5",
    "phpstan/phpstan": "^2.0",
    "dg/bypass-finals": "^1.9"
  },
  "bin": [
    "bin/schemakeeper"
  ]
}
