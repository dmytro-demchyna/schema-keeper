#!/usr/bin/env php
<?php

/**
 * This file is part of the SchemaKeeper package.
 * (c) Dmytro Demchyna <dmytro.demchyna@gmail.com>
 * For the full copyright and license information, please view the LICENSE file that was distributed with this source code.
 */

declare(strict_types=1);

use SchemaKeeper\Cli\{ArgvParser, CredentialsFactory, DiffBuilder, EntryPoint};
use SchemaKeeper\KeeperFactory;

if (version_compare(PHP_VERSION, '7.4.0', '<')) {
    fwrite(STDERR, 'SchemaKeeper requires PHP >= 7.4' . PHP_EOL);

    exit(1);
}

$autoloadVariants = [
    __DIR__ . '/../../../autoload.php',
    __DIR__ . '/../vendor/autoload.php',
];

$autoloadPath = null;

foreach ($autoloadVariants as $variantPath) {
    if (file_exists($variantPath)) {
        $autoloadPath = $variantPath;

        break;
    }
}

if (!$autoloadPath) {
    fwrite(
        STDERR,
        'You must set up the project dependencies:' . PHP_EOL .
        'curl -s http://getcomposer.org/installer | php' . PHP_EOL .
        'php composer.phar install' . PHP_EOL,
    );

    exit(1);
}

require_once $autoloadPath;

$entryPoint = new EntryPoint(
    new ArgvParser(new CredentialsFactory()),
    new KeeperFactory(),
    new DiffBuilder(),
);
$result = $entryPoint->run($argv);

if ($result->getMessage() !== '') {
    echo $result->getMessage() . PHP_EOL;
}

exit($result->getStatus());
